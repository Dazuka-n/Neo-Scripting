# =============================================================================
# Intelliwrite — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================


# ── REQUIRED ─────────────────────────────────────────────────────────────────
# The app will refuse to start if any of these are missing.

# Google Gemini API key (get one free at https://aistudio.google.com)
# The Researcher agent is hard-pinned to Gemini.
GEMINI_API_KEY=your_gemini_api_key_here

# Qdrant vector database URL
# Local Docker:  docker run -d -p 6333:6333 qdrant/qdrant  →  http://localhost:6333
# Qdrant Cloud:  https://your-cluster.qdrant.io
QDRANT_URL=http://localhost:6333

# Qdrant API key
# Local Docker:  use any non-empty string (e.g. "local")
# Qdrant Cloud:  the key from your cluster dashboard
QDRANT_API_KEY=local


# ── OPTIONAL — LLM Providers ─────────────────────────────────────────────────
# Used as fallback LLM providers and for embeddings.
# Leave blank if you only want to use Gemini.

OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=https://localhost
OPENROUTER_APP_NAME=Intelliwrite


# ── OPTIONAL — LLM Model Config ──────────────────────────────────────────────
# Override the default model / provider for all agents.
# Defaults to Gemini Flash if not set.

LLM_PROVIDER=google
MODEL_NAME=models/gemini-flash-latest

# Override per-agent (all default to LLM_PROVIDER / MODEL_NAME above)
# RESEARCHER_MODEL=models/gemini-flash-latest
# PLANNER_PROVIDER=google
# PLANNER_MODEL=models/gemini-flash-latest
# WRITER_PROVIDER=google
# WRITER_MODEL=models/gemini-flash-latest
# OPTIMIZER_PROVIDER=google
# OPTIMIZER_MODEL=models/gemini-flash-latest
# QA_PROVIDER=google
# QA_MODEL=models/gemini-flash-latest


# ── OPTIONAL — Knowledge Base ─────────────────────────────────────────────────
# Qdrant collection name (default: aeo_knowledge_base)
COLLECTION_NAME=aeo_knowledge_base

# Embedder provider: auto | openai | openrouter | gemini
# "auto" picks the first available based on which API key is set.
EMBEDDER_PROVIDER=auto


# ── OPTIONAL — Langfuse Observability ────────────────────────────────────────
# Token usage tracking and trace logging. App runs fine without these —
# tracing is silently skipped if keys are missing.
# Sign up free at https://cloud.langfuse.com

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
