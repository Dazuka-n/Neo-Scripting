# =============================================================================
# Intelliwrite Backend — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================


# ── REQUIRED (app will not start without these) ─────────────────────────────

# 1. Google Gemini API key
#    Get one free at: https://aistudio.google.com/apikey
#    The Researcher agent is always pinned to Gemini Flash.
GEMINI_API_KEY=

# 2. Qdrant vector database URL
#    Local Docker:  docker run -d -p 6333:6333 qdrant/qdrant  →  http://localhost:6333
#    Qdrant Cloud:  https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io
#    Free tier at:  https://cloud.qdrant.io
QDRANT_URL=http://localhost:6333

# 3. Qdrant API key
#    Local Docker:  use any non-empty string (e.g. "local")
#    Qdrant Cloud:  copy from your cluster dashboard
QDRANT_API_KEY=local


# ── OPTIONAL — Additional LLM Providers ─────────────────────────────────────
# Used as fallback LLM providers and for embeddings.
# Leave blank if you only want to use Gemini for everything.

# OpenAI (for embeddings + optional agent overrides)
#   Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenRouter (multi-model gateway, optional)
#   Get a key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=https://localhost
OPENROUTER_APP_NAME=Intelliwrite


# ── OPTIONAL — Default LLM Model Config ─────────────────────────────────────
# Override the default model / provider for ALL agents.
# Defaults to Gemini Flash if not set.

LLM_PROVIDER=google
MODEL_NAME=models/gemini-flash-latest

# Per-agent overrides (uncomment to customize individual agents)
# Each agent falls back to LLM_PROVIDER / MODEL_NAME above if not set.
#
# RESEARCHER_MODEL=models/gemini-flash-latest     # always uses google provider
# PLANNER_PROVIDER=google
# PLANNER_MODEL=models/gemini-flash-latest
# WRITER_PROVIDER=google
# WRITER_MODEL=models/gemini-flash-latest
# OPTIMIZER_PROVIDER=google
# OPTIMIZER_MODEL=models/gemini-flash-latest
# QA_PROVIDER=google
# QA_MODEL=models/gemini-flash-latest


# ── OPTIONAL — Knowledge Base ───────────────────────────────────────────────
# Qdrant collection name (default: aeo_knowledge_base)
COLLECTION_NAME=aeo_knowledge_base

# Embedder provider: auto | openai | openrouter | gemini
# "auto" picks the first available based on which API key is set.
EMBEDDER_PROVIDER=auto


# ── OPTIONAL — Langfuse Observability ───────────────────────────────────────
# Token usage tracking and trace logging across the full pipeline.
# App runs perfectly fine without these — tracing is silently skipped.
# Sign up free at: https://cloud.langfuse.com

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
