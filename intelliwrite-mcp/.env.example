# =============================================================================
# neo-scripting-mcp — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ── REQUIRED ─────────────────────────────────────────────────────────────────
# URL of your deployed Neo Scripting FastAPI backend.
# Local dev:   http://localhost:8000
# Production:  https://api.neo-scripting.ai  (or your Railway / Render URL)
API_BASE_URL=http://localhost:8000

# ── OPTIONAL ─────────────────────────────────────────────────────────────────
# Port the MCP server listens on (default: 8080)
PORT=8080

# Logging verbosity: DEBUG | INFO | WARNING | ERROR (default: info)
LOG_LEVEL=info


# ── AUTHENTICATION ───────────────────────────────────────────────────────────
# Required in production. When set, every SSE connection must include
# the header: X-MCP-Secret: <this-value>
#
# In Claude.ai: Connector settings → Headers → add: X-MCP-Secret: <your-secret>
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
#
# Leave unset for local development (server runs unauthenticated).
# MCP_SECRET=your-shared-secret-here
