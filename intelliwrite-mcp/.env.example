# =============================================================================
# intelliwrite-mcp — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ── REQUIRED ─────────────────────────────────────────────────────────────────
# URL of your deployed Intelliwrite FastAPI backend.
# Local dev:   http://localhost:8000
# Production:  https://api.intelliwrite.ai  (or your Railway / Render URL)
API_BASE_URL=http://localhost:8000

# ── OPTIONAL ─────────────────────────────────────────────────────────────────
# Port the MCP server listens on (default: 8080)
PORT=8080

# Log level: debug | info | warning (default: info)
LOG_LEVEL=info
